---
import Layout from '../layouts/Layout.astro';
import { getSupabaseServerClient } from '../lib/supabase';

if (!Astro.locals.user) {
	return Astro.redirect('/login');
}

const supabase = getSupabaseServerClient(Astro.cookies, Astro.request);
const { data: cards, error } = await supabase
	.from('cards')
	.select('id, visible_name, brand, issuer_bank, closing_day, due_day')
	.order('created_at', { ascending: false });

const { data: purchases, error: purchasesError } = await supabase
	.from('purchases')
	.select(
		'id, name, total_amount, purchase_date, installments_count, purchase_allocations(amount, cards(visible_name), installment_plans(installments_count, installments(id, installment_number, due_date, amount, status, paid_at)))'
	)
	.order('created_at', { ascending: false });

const purchaseErrorMessage = Astro.url.searchParams.get('purchase_error');
const purchaseSuccess = Astro.url.searchParams.get('purchase_success') === '1';
const cardErrorMessage = Astro.url.searchParams.get('card_error');
const cardSuccess = Astro.url.searchParams.get('card_success') === '1';
const installmentErrorMessage = Astro.url.searchParams.get('installment_error');
const installmentSuccess = Astro.url.searchParams.get('installment_success') === '1';
const actionMode = Astro.url.searchParams.get('action');

const formatCurrency = (amount: number | string) => `$${Number(amount).toFixed(2)}`;

const formatDate = (date: string) =>
	new Intl.DateTimeFormat('es-AR', {
		day: '2-digit',
		month: '2-digit',
		year: 'numeric'
	}).format(new Date(`${date}T00:00:00`));

type PendingPurchaseSummary = {
	purchaseName: string;
	allocationSummary: string;
	nextPendingInstallment: {
		id: string;
		installment_number: number;
		due_date: string;
		amount: number;
		status: string;
		paid_at: string | null;
	};
	pendingInstallmentsCount: number;
};

const pendingPurchases = (purchases ?? []).reduce<PendingPurchaseSummary[]>((summaries, purchase) => {
	const allocations = Array.isArray(purchase.purchase_allocations) ? purchase.purchase_allocations : [];

	const allocationSummary = allocations
		.map((allocation) => {
			const card = Array.isArray(allocation.cards) ? allocation.cards[0] : allocation.cards;
			const cardName = card?.visible_name ?? 'Tarjeta';
			const plans = Array.isArray(allocation.installment_plans)
				? allocation.installment_plans
				: allocation.installment_plans
					? [allocation.installment_plans]
					: [];
			const installmentsCount = plans[0]?.installments_count;
			const installmentsLabel =
				typeof installmentsCount === 'number'
					? ` · ${installmentsCount} cuota${installmentsCount === 1 ? '' : 's'}`
					: '';

			return `${cardName}: ${formatCurrency(allocation.amount)}${installmentsLabel}`;
		})
		.join(' · ');

	const allInstallments = allocations.flatMap(
		(allocation) => {
			const plans = Array.isArray(allocation.installment_plans)
				? allocation.installment_plans
				: allocation.installment_plans
					? [allocation.installment_plans]
					: [];

			return plans.flatMap((plan) => plan.installments ?? []);
		}
	);

	const pendingInstallments = allInstallments
		.filter((installment) => installment.status !== 'paid')
		.sort((a, b) => {
			const dueDateDiff = a.due_date.localeCompare(b.due_date);
			if (dueDateDiff !== 0) return dueDateDiff;

			return a.installment_number - b.installment_number;
		});

	const nextPendingInstallment = pendingInstallments[0];

	if (!nextPendingInstallment) {
		return summaries;
	}

	summaries.push({
		purchaseName: purchase.name,
		allocationSummary,
		nextPendingInstallment,
		pendingInstallmentsCount: pendingInstallments.length
	});

	return summaries;
}, []);

pendingPurchases.sort(
	(a, b) => a.nextPendingInstallment.due_date.localeCompare(b.nextPendingInstallment.due_date)
);
---

<Layout title="Dashboard | Cuoting">
	<header class="mb-6 flex items-center justify-between">
		<div>
			<h1 class="text-2xl font-semibold">Tus tarjetas</h1>
			<p class="text-sm text-slate-600">Usuario: {Astro.locals.user.email}</p>
		</div>
		<form method="post" action="/api/auth/logout">
			<button type="submit">Salir</button>
		</form>
	</header>

	<section class="mb-8 rounded-lg bg-white p-6 shadow-sm">
		<h2 class="mb-4 text-lg font-semibold">Acciones</h2>
		<div class="flex flex-wrap gap-2">
			<a href="/dashboard?action=card" role="button">Agregar tarjeta</a>
			<a href="/dashboard?action=purchase" role="button">Agregar compra en cuotas</a>
			{actionMode && (
				<a href="/dashboard" role="button" class="bg-slate-200 text-slate-900 hover:bg-slate-300"
					>Volver al resumen</a
				>
			)}
		</div>
	</section>

	{actionMode === 'card' && (
		<section class="mb-8 rounded-lg bg-white p-6 shadow-sm">
			<h2 class="mb-4 text-lg font-semibold">Agregar tarjeta</h2>
			{cardErrorMessage && <p class="mb-3 text-sm text-red-600">{cardErrorMessage}</p>}
			{cardSuccess && <p class="mb-3 text-sm text-emerald-700">Tarjeta creada correctamente.</p>}
			<form method="post" action="/api/cards/create" class="grid gap-3 sm:grid-cols-2">
				<input name="visible_name" placeholder="Nombre visible" required />
				<input name="brand" placeholder="Marca (Visa, Master, etc.)" required />
				<input name="issuer_bank" placeholder="Banco emisor" required />
				<input name="closing_day" type="number" min="1" max="31" placeholder="Día de cierre" required />
				<input name="due_day" type="number" min="1" max="31" placeholder="Día de vencimiento" required />
				<button type="submit" class="sm:col-span-2">Crear tarjeta</button>
			</form>
		</section>
	)}

	{actionMode === 'purchase' && (
		<section class="mb-8 rounded-lg bg-white p-6 shadow-sm">
			<h2 class="mb-4 text-lg font-semibold">Agregar compra en cuotas</h2>
			{purchaseErrorMessage && <p class="mb-3 text-sm text-red-600">{purchaseErrorMessage}</p>}
			{purchaseSuccess && <p class="mb-3 text-sm text-emerald-700">Compra creada correctamente.</p>}
			<form method="post" action="/api/purchases/create" class="space-y-4" id="purchase-form">
				<div class="grid gap-3 sm:grid-cols-2">
					<input name="name" placeholder="Nombre de la compra" required />
					<input
						name="total_amount"
						id="purchase-total-amount"
						type="number"
						step="0.01"
						min="0.01"
						placeholder="Monto total"
						required
					/>
					<input name="purchase_date" type="date" required />
				</div>

				<div>
					<div class="mb-2 flex items-center justify-between">
						<h3 class="text-sm font-semibold">Asignaciones por tarjeta</h3>
						<button type="button" id="add-allocation">+ Agregar asignación</button>
					</div>
					<p class="mb-3 text-sm text-slate-600">
						En cada fila cargá el <strong>monto total que va en esa tarjeta</strong> y en cuántas cuotas se
						divide. No pongas el valor de una sola cuota.
					</p>
					<div id="allocations" class="space-y-2">
						<div class="allocation-row grid gap-3 sm:grid-cols-[1fr_140px_140px_auto]">
							<select name="allocation_card_id" required>
								<option value="">Tarjeta</option>
								{cards?.map((card) => (
									<option value={card.id}>{card.visible_name} · {card.brand}</option>
								))}
							</select>
							<input
								name="allocation_amount"
								type="number"
								step="0.01"
								min="0.01"
								placeholder="Monto total en esta tarjeta"
								required
							/>
							<input
								name="allocation_installments_count"
								type="number"
								min="1"
								max="120"
								placeholder="Cantidad de cuotas"
								required
							/>
							<button type="button" class="remove-allocation">Quitar</button>
						</div>
					</div>
					<div class="mt-3 rounded-md bg-slate-50 p-3 text-sm text-slate-700">
						<p><strong>Total de la compra:</strong> <span id="purchase-total-preview">$0.00</span></p>
						<p><strong>Total asignado:</strong> <span id="allocations-total-preview">$0.00</span></p>
						<p><strong>Diferencia:</strong> <span id="allocations-difference-preview">$0.00</span></p>
					</div>
					<p class="mt-2 text-xs text-slate-600">
						La suma de los montos asignados debe ser igual al monto total de la compra.
					</p>
				</div>

				<button type="submit">Crear compra</button>
			</form>
		</section>
	)}

	<section class="rounded-lg bg-white p-6 shadow-sm">
		<h2 class="mb-4 text-lg font-semibold">Listado</h2>
		{error && <p class="text-sm text-red-600">Error cargando tarjetas: {error.message}</p>}
		{!cards?.length && !error && <p class="text-sm text-slate-600">Todavía no cargaste tarjetas.</p>}
		<ul class="space-y-3">
			{cards?.map((card) => (
				<li class="rounded-md border border-slate-200 p-3">
					<p class="font-medium">{card.visible_name}</p>
					<p class="text-sm text-slate-600">{card.brand} · {card.issuer_bank}</p>
					<p class="text-sm text-slate-600">Cierre: día {card.closing_day} · Vence: día {card.due_day}</p>
				</li>
			))}
		</ul>
	</section>

	<section class="mt-8 rounded-lg bg-white p-6 shadow-sm">
		<h2 class="mb-4 text-lg font-semibold">Cuotas pendientes</h2>
		{installmentErrorMessage && <p class="mb-3 text-sm text-red-600">{installmentErrorMessage}</p>}
		{installmentSuccess && <p class="mb-3 text-sm text-emerald-700">Cuota marcada como pagada.</p>}
		{purchasesError && <p class="text-sm text-red-600">Error cargando compras: {purchasesError.message}</p>}
		{!pendingPurchases.length && !purchasesError && (
			<p class="text-sm text-slate-600">No tenés cuotas pendientes.</p>
		)}
		<ul class="space-y-3">
			{pendingPurchases.map(
				({ purchaseName, allocationSummary, nextPendingInstallment, pendingInstallmentsCount }) => (
				<li class="rounded-md border border-slate-200 p-3">
					<p class="font-medium">{purchaseName}</p>
					{allocationSummary && <p class="text-sm text-slate-600">{allocationSummary}</p>}
					<p class="text-sm text-slate-600">
						Próxima cuota #{nextPendingInstallment.installment_number} · vence{' '}
						{formatDate(nextPendingInstallment.due_date)}
					</p>
					<p class="text-sm text-slate-600">Monto: {formatCurrency(nextPendingInstallment.amount)}</p>
					<p class="text-sm text-slate-600">
						Quedan {pendingInstallmentsCount} cuota{pendingInstallmentsCount === 1 ? '' : 's'} pendiente
						{pendingInstallmentsCount === 1 ? '' : 's'}.
					</p>
					<p class="text-sm text-amber-700">Estado: pendiente</p>
					<form method="post" action="/api/installments/mark-paid" class="mt-2">
						<input type="hidden" name="installment_id" value={nextPendingInstallment.id} />
						<button type="submit">Marcar próxima cuota como pagada</button>
					</form>
				</li>
				)
			)}
		</ul>
	</section>
</Layout>

<script>
	const allocationsContainer = document.querySelector('#allocations');
	const addButton = document.querySelector('#add-allocation');
	const totalAmountInput = document.querySelector('#purchase-total-amount');
	const purchaseTotalPreview = document.querySelector('#purchase-total-preview');
	const allocationsTotalPreview = document.querySelector('#allocations-total-preview');
	const allocationsDifferencePreview = document.querySelector('#allocations-difference-preview');

	const formatCurrency = (value) =>
		new Intl.NumberFormat('es-AR', {
			style: 'currency',
			currency: 'ARS'
		}).format(value);

	const parseAmount = (value) => {
		const parsed = Number.parseFloat(String(value ?? '0'));
		return Number.isFinite(parsed) ? parsed : 0;
	};

	const refreshAllocationSummary = () => {
		const totalAmount =
			totalAmountInput instanceof HTMLInputElement ? parseAmount(totalAmountInput.value) : 0;

		const allocatedAmount = allocationsContainer
			? Array.from(allocationsContainer.querySelectorAll('input[name="allocation_amount"]')).reduce(
					(sum, field) => sum + (field instanceof HTMLInputElement ? parseAmount(field.value) : 0),
					0
				)
			: 0;

		const difference = totalAmount - allocatedAmount;

		if (purchaseTotalPreview) purchaseTotalPreview.textContent = formatCurrency(totalAmount);
		if (allocationsTotalPreview) allocationsTotalPreview.textContent = formatCurrency(allocatedAmount);
		if (allocationsDifferencePreview) allocationsDifferencePreview.textContent = formatCurrency(difference);
	};

	const refreshRemoveButtons = () => {
		const rows = allocationsContainer?.querySelectorAll('.allocation-row');
		rows?.forEach((row, index) => {
			const removeButton = row.querySelector('.remove-allocation');
			if (removeButton instanceof HTMLButtonElement) {
				removeButton.disabled = rows.length === 1;
				removeButton.onclick = () => {
					if (rows.length > 1) {
						row.remove();
						refreshRemoveButtons();
						refreshAllocationSummary();
					}
				};
			}
		});
	};

	addButton?.addEventListener('click', () => {
		const templateRow = allocationsContainer?.querySelector('.allocation-row');
		if (!templateRow || !allocationsContainer) return;

		const clone = templateRow.cloneNode(true);
		if (!(clone instanceof HTMLElement)) return;

		clone.querySelectorAll('input, select').forEach((field) => {
			if (field instanceof HTMLInputElement || field instanceof HTMLSelectElement) {
				field.value = '';
			}
		});

		allocationsContainer.appendChild(clone);
		refreshRemoveButtons();
		refreshAllocationSummary();
	});

	totalAmountInput?.addEventListener('input', refreshAllocationSummary);
	allocationsContainer?.addEventListener('input', refreshAllocationSummary);

	refreshRemoveButtons();
	refreshAllocationSummary();
</script>
