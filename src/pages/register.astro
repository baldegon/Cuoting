---
import Layout from '../layouts/Layout.astro';

if (Astro.locals.user) {
	return Astro.redirect('/dashboard');
}

const error = Astro.url.searchParams.get('error');
const success = Astro.url.searchParams.get('success');
---

<Layout title="Registro | Cuoting">
	<section class="mx-auto max-w-md space-y-6 rounded-lg bg-white p-6 shadow-sm">
		<h1 class="text-2xl font-semibold">Creá tu cuenta</h1>
		<p class="text-sm text-slate-600">Registro simple para usar el MVP sin alta manual en Supabase.</p>

		{error && <p class="rounded-md bg-red-100 p-2 text-sm text-red-700">{error}</p>}
		{success && <p class="rounded-md bg-green-100 p-2 text-sm text-green-700">{success}</p>}

		<form method="post" action="/api/auth/register" class="space-y-4">
			<label class="block space-y-1">
				<span class="text-sm font-medium">Email</span>
				<input type="email" name="email" required />
			</label>
			<label class="block space-y-1">
				<span class="text-sm font-medium">Contraseña</span>
				<input type="password" name="password" minlength="8" required />
			</label>
			<label class="block space-y-1">
				<span class="text-sm font-medium">Confirmá tu contraseña</span>
				<input type="password" name="confirmPassword" minlength="8" required />
			</label>
			<button type="submit" class="w-full">Crear cuenta</button>
		</form>

		<p class="text-sm text-slate-600">
			¿Ya tenés cuenta?
			<a class="font-medium text-slate-900 underline" href="/login">Ingresá acá</a>
		</p>
	</section>
</Layout>
