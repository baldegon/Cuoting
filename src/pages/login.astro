---
import Layout from '../layouts/Layout.astro';

if (Astro.locals.user) {
	return Astro.redirect('/dashboard');
}

const error = Astro.url.searchParams.get('error');
---

<Layout title="Login | Cuoting">
	<section class="mx-auto max-w-md space-y-6 rounded-lg bg-white p-6 shadow-sm">
		<h1 class="text-2xl font-semibold">Ingresá a Cuoting</h1>
		<p class="text-sm text-slate-600">Usamos Supabase Auth con email y contraseña.</p>

		{error && <p class="rounded-md bg-red-100 p-2 text-sm text-red-700">{error}</p>}

		<form method="post" action="/api/auth/login" class="space-y-4">
			<label class="block space-y-1">
				<span class="text-sm font-medium">Email</span>
				<input type="email" name="email" required />
			</label>
			<label class="block space-y-1">
				<span class="text-sm font-medium">Contraseña</span>
				<input type="password" name="password" required />
			</label>
			<button type="submit" class="w-full">Entrar</button>
		</form>
	</section>
</Layout>
